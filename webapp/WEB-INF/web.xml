<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  version="6.0">

  <display-name>Impftermin-Buchungssystem</display-name>

  <!-- Redis-Konfiguration -->
  <context-param>
    <param-name>redisserver</param-name>
    <param-value>redis</param-value>
  </context-param>
  <context-param>
    <param-name>redispassword</param-name>
    <param-value></param-value>
  </context-param>

  <!-- Redis-Initialisierung beim Start -->
  <listener>
    <listener-class>hbv.web.MyContextListener</listener-class>
  </listener>

  <!-- Servlets -->
  <servlet>
    <servlet-name>registerServlet</servlet-name>
    <servlet-class>hbv.web.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>registerServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>loginServlet</servlet-name>
    <servlet-class>hbv.web.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>loginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>logoutServlet</servlet-name>
    <servlet-class>hbv.web.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>logoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>buchungServlet</servlet-name>
    <servlet-class>hbv.web.BuchungServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>buchungServlet</servlet-name>
    <url-pattern>/buchung</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>terminA</servlet-name>
    <servlet-class>hbv.web.TerminA</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>terminA</servlet-name>
    <url-pattern>/termina</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>deleteT</servlet-name>
    <servlet-class>hbv.web.DeleteT</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>deleteT</servlet-name>
    <url-pattern>/deletet</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>sendMail</servlet-name>
    <servlet-class>hbv.web.SendMail</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>sendMail</servlet-name>
    <url-pattern>/sendmail</url-pattern>
  </servlet-mapping>

</web-app>
